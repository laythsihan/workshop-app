    "officeparser": "^6.0.4",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-pdf": "^10.3.0",
    "resend": "^6.9.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.4.0",
