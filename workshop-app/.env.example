# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# Base URL of your app (must match the URL you open in the browser).
# OAuth redirect URIs are derived from this; the port must match exactly.
# Example: if you run `npm run dev` and open http://localhost:3000, use:
#   NEXTAUTH_URL="http://localhost:3000"
# Do not add /api/auth to this URL.
NEXTAUTH_URL="http://localhost:3000"

# Next Auth OAuth Providers
# Google: Create credentials at https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google (e.g. http://localhost:3000/api/auth/callback/google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Discord: Create application at https://discord.com/developers/applications
# In OAuth2 → Redirects, add exactly: {NEXTAUTH_URL}/api/auth/callback/discord
# (e.g. http://localhost:3000/api/auth/callback/discord — port must match NEXTAUTH_URL)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/workshop-app"

# Supabase (Storage for file uploads)
# From Project Settings > API: Project URL and service_role key (secret)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
